# This repo holds only source + config. The BABS runtime — DataLad datasets,
# RIA stores, the .sif image, the micromamba env, logs — lives outside Dropbox
# under ~/babs_hcp and is never committed (git-annex content must not be
# Dropbox-synced).
__pycache__/
*.pyc
*.sif
*.log

